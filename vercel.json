{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/test",
            "destination": "/api/test.cjs"
        },
        {
            "source": "/api/debug-bundle",
            "destination": "/api/debug-bundle.cjs"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.cjs"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}